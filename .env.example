# FakeNewsID - Environment Configuration
# Copy this file to .env and fill in your API keys

PORT=3000

# NewsAPI.org - Get free key at https://newsapi.org (100 req/day free)
NEWSAPI_KEY=your_newsapi_key_here

# Twitter/X API v2 - Bearer token from developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Bing News Search API - From Azure Cognitive Services
BING_NEWS_KEY=your_bing_news_key_here

# Note: Google News RSS, Reddit, and Wayback Machine are FREE - no keys needed

# ── LLM Analysis (optional — enables AI-powered content analysis) ──────────
# Add any of these to enable that provider in the UI selector

# Anthropic Claude — platform.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI ChatGPT — platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
